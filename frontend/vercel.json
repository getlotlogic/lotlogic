{
  "rewrites": [
    { "source": "/", "destination": "/home.html" },
    { "source": "/visit/:path*", "destination": "/visit.html" },
    { "source": "/register/:path*", "destination": "/resident.html" },
    { "source": "/leasing/:path*", "destination": "/leasing.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/:path*", "destination": "/index.html" },
    { "source": "/:path((?!home\\.html|visit\\.|resident\\.|leasing\\.|pitch-|blog|robots\\.txt|sitemap\\.xml|app).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
