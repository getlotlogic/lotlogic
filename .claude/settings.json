{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-secrets-scan.sh",
            "description": "Block Write/Edit to *.md, *.html, *.yml, and docs/** when content contains known secret patterns."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/edge-function-checked-in.sh",
            "description": "Block `supabase functions deploy <name>` when supabase/functions/<name>/ is missing or has uncommitted/untracked changes."
          }
        ]
      }
    ]
  }
}
