# LotLogic Monitoring Agent — Environment Variables
# Copy this to .env and fill in your values

# Required: Claude API key for AI analysis
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: Your deployed dashboard URL
DASHBOARD_URL=https://your-app.up.railway.app

# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Direct Postgres connection (for advanced queries)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
