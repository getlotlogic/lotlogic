# LotLogic Snapshot Puller — Environment Variables
# Copy this to .env and fill in your values

# Required: Backend API key
LOTLOGIC_API_KEY=your-api-key-here

# Required: Supabase connection (use service_role key for server-side writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Required for RTSP cameras: camera credentials
CAMERA_USER=admin
CAMERA_PASS=your-camera-password

# Optional: Backend API URL (defaults to production)
# LOTLOGIC_API_URL=https://lotlogic-backend-production.up.railway.app

# Optional: Direct HTTP camera URL
# CAMERA_HTTP_URL=http://192.168.1.100/ISAPI/Streaming/channels/101/picture
