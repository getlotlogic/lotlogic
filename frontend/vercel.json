{
  "rewrites": [
    { "source": "/temp/:path*", "destination": "/visit.html" },
    { "source": "/perm/:path*", "destination": "/resident.html" },
    { "source": "/visit/:path*", "destination": "/visit.html" },
    { "source": "/register/:path*", "destination": "/resident.html" },
    { "source": "/app", "destination": "/dashboard.html" },
    { "source": "/app/:path*", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
